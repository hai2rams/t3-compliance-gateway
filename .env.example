PORT=4000

# Run sponsor adapters in mock mode (no live API keys required)
MOCK_MODE=true

# Hackathon compliance/check LLM routing: kimi (default) | gemini (optional legacy)
LLM_PROVIDER=kimi
KIMI_API_KEY=
TOKENROUTER_API_KEY=
DAYTONA_API_KEY=
NOSANA_API_KEY=
SENSENOVA_API_KEY=
VIDEODB_API_KEY=

# Terminal 3 developer key from https://docs.terminal3.io/developers/adk/get-started/prerequisites/request-test-tokens
T3N_API_KEY=

# testnet | production
T3N_ENVIRONMENT=testnet

# Numeric contract id used for secrets map ACL (writers/readers: only [contractId])
T3N_CONTRACT_ID=

# Contract tail used at registration (do not include z:<tid>: prefix)
T3N_CONTRACT_TAIL=compliance-gateway-v1
T3N_CONTRACT_VERSION=0.1.0

# Compliance keys seeded into z::<tenant>:secrets (map-entry-set)
COMPLIANCE_POLICY_VERSION=1.0.0
COMPLIANCE_REGION=us
AUDIT_WEBHOOK_SECRET=

# Layer 2 semantic audit (fallback if gemini_api_key is not sealed in z::secrets)
GEMINI_API_KEY=
