PORT=3000

# Terminal 3 developer key from https://docs.terminal3.io/developers/adk/get-started/prerequisites/request-test-tokens
T3N_API_KEY=

# testnet | production
T3N_ENVIRONMENT=testnet

# Numeric contract id used for secrets map ACL (writers/readers: only [contractId])
T3N_CONTRACT_ID=

# Optional: contract tail when invoking TEE reads later
T3N_CONTRACT_TAIL=compliance-gateway-v1

# Compliance keys seeded into z::<tenant>:secrets (map-entry-set)
COMPLIANCE_POLICY_VERSION=1.0.0
COMPLIANCE_REGION=us
AUDIT_WEBHOOK_SECRET=
